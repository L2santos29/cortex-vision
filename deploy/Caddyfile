# Caddyfile for Cortex-Vision Staging
# Replace staging.example.com with your real domain
# Automatic TLS via Let's Encrypt

staging.example.com {
    # Reverse proxy to the app container
    reverse_proxy cortex-vision:8000

    # Security headers (in case the proxy is external-facing)
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        Referrer-Policy "strict-origin-when-cross-origin"
    }

    # Access logging
    log {
        output file /data/access.log
        format json
    }

    # Proxy-level rate limiting
    rate_limit {
        zone dynamic {
            key {remote_host}
            events 100
            window 1m
        }
    }
}
