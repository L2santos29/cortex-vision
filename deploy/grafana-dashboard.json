{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Prometheus data source",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "9.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "5.0.0" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" }
  ],
  "id": null,
  "title": "Cortex-Vision / Overview",
  "tags": ["cortex-vision", "object-detection"],
  "schemaVersion": 36,
  "version": 1,
  "refresh": "30s",
  "timezone": "browser",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Health Status",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red", "value": null },
            { "color": "green", "value": 1 }
          ]},
          "unit": "none",
          "mappings": [{ "type": "value", "value": "1", "text": "UP" }]
        }
      },
      "options": { "reduceOptions": { "values": false, "calcs": ["last"] }, "orientation": "auto" },
      "targets": [{
        "expr": "up{job=\"cortex-vision\"}",
        "legendFormat": "",
        "refId": "A"
      }],
      "description": "Shows UP if the Cortex-Vision instance is reachable via Prometheus target scraping."
    },
    {
      "id": 2,
      "title": "Request Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 10, "x": 4, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "req/s",
          "color": { "mode": "palette-classic" },
          "custom": { "lineInterpolation": "smooth", "showPoints": "never" }
        }
      },
      "options": { "legend": { "displayMode": "table", "placement": "right" }, "tooltip": { "mode": "multi" } },
      "targets": [{
        "expr": "rate(cortex_vision_request_count[5m])",
        "legendFormat": "{{ route }}",
        "refId": "A"
      }],
      "description": "Requests per second broken down by API route."
    },
    {
      "id": 3,
      "title": "P99 Latency",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 10, "x": 14, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "palette-classic" },
          "custom": { "lineInterpolation": "smooth", "showPoints": "never" }
        }
      },
      "options": { "legend": { "displayMode": "table", "placement": "right" }, "tooltip": { "mode": "multi" } },
      "targets": [{
        "expr": "cortex_vision_request_latency_seconds{quantile=\"p99\"}",
        "legendFormat": "{{ route }}",
        "refId": "A"
      }],
      "description": "P99 latency per route. Spikes above 10s trigger the CortexVisionHighLatency alert."
    },
    {
      "id": 4,
      "title": "Average Latency",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 10, "x": 4, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "palette-classic" },
          "custom": { "lineInterpolation": "smooth", "showPoints": "never" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "orange", "value": 5 },
            { "color": "red", "value": 10 }
          ]}
        }
      },
      "options": { "legend": { "displayMode": "table", "placement": "right" }, "tooltip": { "mode": "multi" } },
      "targets": [{
        "expr": "cortex_vision_request_latency_seconds{quantile=\"avg\"}",
        "legendFormat": "{{ route }}",
        "refId": "A"
      }],
      "description": "Average latency per route. Orange >5s, Red >10s."
    },
    {
      "id": 5,
      "title": "Total Requests",
      "type": "timeseries",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 4 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "fixed", "fixedColor": "blue" },
          "custom": { "lineInterpolation": "smooth", "showPoints": "never" }
        }
      },
      "options": { "legend": { "displayMode": "hidden" }, "tooltip": { "mode": "single" } },
      "targets": [{
        "expr": "sum(cortex_vision_request_count)",
        "legendFormat": "Total",
        "refId": "A"
      }],
      "description": "Cumulative total of all API requests received."
    }
  ]
}
