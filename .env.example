# Cortex-Vision Configuration
# Copy this file to .env and adjust values for your environment.

# Server
HOST=0.0.0.0
PORT=8000

# Storage directories (relative to project root)
UPLOAD_DIR=uploads
OUTPUT_DIR=output

# YOLO model (n, s, m, l, x)
YOLO_MODEL=yolov8n.pt

# Security: API key for protected endpoints
# Change this to a strong random value in production
API_KEY=dev-key-do-not-use-in-production

# Security: Allowed CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:8000

# Security: Rate limiting
RATE_LIMIT=30
RATE_WINDOW=60
